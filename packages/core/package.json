{
  "name": "@yves-epub/core",
  "version": "0.1.3",
  "description": "Browser EPUB reader engine with parsing, hybrid rendering, navigation,search, bookmarks, annotations, and reader preferences.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaoyunfei0816/yves-epubjs.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/xiaoyunfei0816/yves-epubjs/issues"
  },
  "homepage": "https://github.com/xiaoyunfei0816/yves-epubjs#readme",
  "keywords": [
    "epub",
    "reader",
    "ebook",
    "typescript",
    "canvas",
    "dom"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --tsconfig tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cd ../.. && vitest run"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "css-select": "^5.1.0",
    "css-tree": "^3.2.1",
    "domhandler": "^5.0.3",
    "eventemitter3": "^5.0.1",
    "fast-xml-parser": "^4.5.3",
    "fflate": "^0.8.2",
    "htmlparser2": "^9.1.0",
    "nanoid": "^5.1.5"
  }
}
