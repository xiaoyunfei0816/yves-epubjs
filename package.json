{
  "name": "pretext-epub-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "ci:check": "pnpm typecheck && pnpm check:boundaries && pnpm lint && pnpm test && pnpm build",
    "dev": "pnpm --filter @pretext-epub/demo dev",
    "sync:citic-core": "node scripts/sync-citic-pretext-core.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs,.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "playwright": "^1.54.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,css}": [
      "prettier --write"
    ]
  }
}
